# Copy to .env and fill in real values. Never commit .env.

# --- Database (Prisma / Neon or any Postgres) ---
# Connection string for your Postgres instance (Neon, Supabase, RDS, local, ...).
DATABASE_URL="postgresql://user:password@localhost:5432/lawfirm?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
# Must be set to the real origin (e.g. https://app.sovereignapexlegal.example
# in production, http://localhost:3000 in dev) — leaving it as an empty
# string breaks Auth.js's trusted-host check (unlike leaving it unset
# entirely).
AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# Used both for magic-link sign-in and transactional notifications.
RESEND_API_KEY=""
EMAIL_FROM="Sovereign Apex Legal LLP <no-reply@sovereignapexlegal.example>"

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO for local dev) ---
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Upstash Redis ---
# Required to boot the app now, not just for rate limiting: client/attorney
# accounts and demo matters/documents are stored here (src/lib/redis.ts),
# not in a local file or Postgres, specifically so this deploys cleanly to
# Vercel's serverless functions (no writable disk, no memory shared across
# instances). Free tier at https://upstash.com is enough for this.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
