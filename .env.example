# Copy to .env and fill in real values. Never commit .env.

# --- Database (Prisma / Neon or any Postgres) ---
# Connection string for your Postgres instance (Neon, Supabase, RDS, local, ...).
DATABASE_URL="postgresql://user:password@localhost:5432/lawfirm?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
# Set in production (e.g. https://app.sterlingvance.example). Not required in local dev.
AUTH_URL=""

# --- Email (Resend) ---
# Used both for magic-link sign-in and transactional notifications.
RESEND_API_KEY=""
EMAIL_FROM="Sterling Vance LLP <no-reply@sterlingvance.example>"

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO for local dev) ---
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
